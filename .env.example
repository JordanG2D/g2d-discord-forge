# Required. Create/reset this in Discord Developer Portal -> Your App -> Bot.
# Never commit or share this token.
DISCORD_BOT_TOKEN=

# Required. Enable Discord Developer Mode, right-click the EXISTING target
# server, and choose Copy Server ID.
TARGET_GUILD_ID=

# Required. Accepts either a Discord template URL or raw template code.
# Example: https://discord.new/AbCdEf123456
DISCORD_TEMPLATE=

# Optional. invite-url can derive this from DISCORD_BOT_TOKEN.
DISCORD_APPLICATION_ID=

# top: place imported channels before existing target content.
# append: place imported channels after existing target content.
FORGE_PLACEMENT=top

# Reuse an existing role/channel only when the match is unambiguous.
FORGE_ADOPT_EXISTING=true

# Temporary Administrator is the reliable way to reproduce permission overwrites.
# Discord role hierarchy still applies.
FORGE_REQUIRE_ADMIN=true

FORGE_STATE_DIR=./state
FORGE_REQUEST_TIMEOUT=30
FORGE_AUDIT_REASON=G2D Discord Forge template import
